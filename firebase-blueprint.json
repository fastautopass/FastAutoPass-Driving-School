{
  "entities": {
    "LocalBusiness": {
      "title": "Local Business",
      "description": "Schema for the FastAutoPass driving school.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "telephone": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "streetAddress": { "type": "string" },
            "addressLocality": { "type": "string" },
            "addressRegion": { "type": "string" },
            "postalCode": { "type": "string" },
            "addressCountry": { "type": "string" }
          }
        }
      }
    },
    "Service": {
      "title": "Service",
      "description": "A driving lesson service offered by FastAutoPass.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "provider": { "$ref": "#/entities/LocalBusiness" },
        "areaServed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "Area": {
      "title": "Area",
      "description": "A specific location or area covered by FastAutoPass.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "city": { "type": "string" },
        "postcode": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/locations/{locationId}": {
      "schema": "Area",
      "description": "Stores information about specific locations/areas covered."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Stores information about driving lesson services."
    }
  }
}
